{
  "name": "pdf-converter",
  "version": "1.0.0",
  "description": "A simple web application to convert PDF files to text documents",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step required for this project'",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docker:build": "docker build -t pdf-converter .",
    "docker:run": "docker run -p 3000:3000 --env-file .env pdf-converter"
  },
  "keywords": [
    "pdf",
    "text-converter",
    "file-processing",
    "web-app",
    "nodejs"
  ],
  "author": "AI Agent Team",
  "license": "MIT",
  "dependencies": {
    "archiver": "^5.3.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "helmet": "^7.0.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "mupdf": "^1.27.0",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "eslint": "^8.45.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/pdf-converter.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/pdf-converter/issues"
  },
  "homepage": "https://github.com/your-username/pdf-converter#readme"
}
