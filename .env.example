# Environment Configuration
NODE_ENV=production
PORT=3000

# OpenRouter API (recommended - cheap vision models via OpenRouter.ai)
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=google/gemini-flash-2.0

# OpenAI API (fallback if no OpenRouter key)
# OPENAI_API_KEY=your_openai_api_key_here

# OCR Configuration
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/4.00/tessdata

# File Processing Configuration
MAX_FILE_SIZE=104857600
MAX_FILES_PER_BATCH=100
CONCURRENT_PROCESSING=3
MAX_VISION_PAGES=10

# Security Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging Configuration
LOG_LEVEL=info
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5
